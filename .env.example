APP_NAME=SafeAgent_Manager
DATABASE_URL=postgresql://postgresql:syeon0424@localhost:5433/safeagent
POLICY_DIR=src/policies
PROMPT_DIR=src/prompts
WORKFLOW_NAME=governance_workflow

# 시스템 입력 정책 (F1 고정 적용 — Stage A)
SYSTEM_INPUT_POLICY_ID=CONTENT_001

# F2 Self-Consistency Check (PRD §5.2.2)
# true  : Judge LLM 2회 병렬 호출 후 verdict 비교 (정확도 ↑, latency ↑)
# false : 단일 호출 (CPU 환경 권장 — 8B 모델 Self-Consistency 는 timeout 위험)
ENABLE_SELF_CONSISTENCY=false

# Governance LLM (F2 Judge / Self-Consistency / Policy Compiler)
# PRD §10.2 권장: qwen3:8b-q4_K_M (정확도 + 한국어 강세)
GOVERNANCE_LLM_URL=http://localhost:11434
GOVERNANCE_LLM_MODEL=qwen3:8b-q4_K_M
GOVERNANCE_LLM_TEMPERATURE=0.1

# Sovereign AI (검사 대상 회사 AI — 데모는 같은 Ollama 공유)
# 운영 시에는 회사의 자체 AI 엔드포인트로 교체
#
# 데이터 주권 가드 (NIST SP 800-53 SC-7(5), PRD §10.1)
# - SOVEREIGN_AI_URL 은 사내 허용 호스트만 가능. 클라우드 LLM 자동 차단.
# - 허용 조건:
#     1) SOVEREIGN_ALLOWED_HOSTS 명시 등록
#     2) RFC 1918 사내 IP (10/8, 172.16/12, 192.168/16, 127/8)
#     기본 허용: localhost, host.docker.internal, ollama
SOVEREIGN_AI_URL=http://localhost:11434
SOVEREIGN_AI_MODEL=qwen2.5:7b
SOVEREIGN_AI_TEMPERATURE=0.7

# 사내 추가 허용 호스트 (콤마 구분, 선택)
# 예: SOVEREIGN_ALLOWED_HOSTS=ollama.internal.company.co.kr,ai-server.corp.company.com
SOVEREIGN_ALLOWED_HOSTS=localhost,host.docker.internal,ollama

# Safe Response Generator (PRD §8 — 차단/거부 시 안전 대체 응답 생성)
# 빠른 응답을 위해 가벼운 모델 권장 (llama3.2:3b)
SAFE_RESPONSE_LLM_URL=http://localhost:11434
SAFE_RESPONSE_LLM_MODEL=llama3.2:3b
SAFE_RESPONSE_LLM_TEMPERATURE=0.3

# Phase 4 인증/권한 (JWT + API Key)
# JWT_SECRET 은 운영 환경에서 최소 32바이트 랜덤 문자열로 교체 필수.
# python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=change-me-in-production-use-at-least-32-bytes-of-randomness
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_TTL_MINUTES=60
JWT_REFRESH_TOKEN_TTL_DAYS=7

# 첫 부팅 시 자동 생성되는 admin 계정의 초기 비밀번호.
# 배포 직후 변경 필수.
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_PASSWORD=changeme
